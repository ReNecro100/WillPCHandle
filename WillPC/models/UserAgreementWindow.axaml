
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="768" d:DesignHeight="1024"
        x:Class="WillPC.UserAgreementWindow"
        Background="#15212C"
        Width="1024"
        Height="768"
		Foreground="White"
        CanResize="False"
        SystemDecorations="None"
        WindowStartupLocation="CenterScreen"
        Title="WillPC">

	<Window.Styles>
	<Style Selector="Button.Agree">
		<Setter Property="Background" Value="#2F80ED"/>
		<Setter Property="Foreground" Value="White"/>
		<Setter Property="FontWeight" Value="SemiBold"/>
		<Setter Property="CornerRadius" Value="8"/>
		<Setter Property="Padding" Value="16,10"/>
		<Setter Property="Transitions">
			<Transitions>
				<BrushTransition Property="Background" Duration="0:0:0.5" Easing="CubicEaseOut"/>
			</Transitions>
		</Setter>
	</Style>
		<Style Selector="Button.Agree:pointerover /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="White"/>
			<!-- Кнопка плавно подсветится -->
		</Style>
		<Style Selector="Button.Decline:pointerover /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="White"/>
			<!-- Кнопка плавно подсветится -->
		</Style>

		<Style Selector="Button.Decline">
			<Setter Property="Background" Value="Red"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="Padding" Value="16,10"/>
			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="Background" Duration="0:0:0.15" Easing="CubicEaseOut"/>
				</Transitions>
			</Setter>
		</Style>

	</Window.Styles>
	<Grid RowDefinitions="Auto, *, Auto">
			
                
                <TextBlock Text="Personal Agreement" Foreground="White"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="10,10,0,16"/>
                <Border Grid.Row="1" Background="#1F2E3D">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock Text="Перед началом использования программного обеспечения
								   WillPC пользователю необходимо в обязательном порядке и максимально внимательно ознакомиться со всеми положениями и условиями
								   данного соглашения. Настоящее приложение создано исключительно для предварительной, приблизительной и ориентировочной оценки 
								   технической возможности запуска различных компьютерных игр и сторонних программных продуктов на персональном компьютере конечного пользователя.
								   Вся информация, расчеты, спецификации и системные требования, отображаемые в интерфейсе приложения, носят сугубо информационный и 
								   справочно-ознакомительный характер, в силу чего они ни при каких обстоятельствах не могут расцениваться как официальная или юридическая
								   гарантия стопроцентной совместимости, высокого уровня производительности, должной частоты кадров или стабильной работы проверяемого софта. Создатель и разработчик
								   данного программного обеспечения полностью и безоговорочно освобождает себя от любой ответственности за возможные технические ошибки в базах данных, неточные или 
								   ошибочные результаты автоматической проверки, аппаратные сбои, а также за любые прямые или косвенные действия пользователя, совершенные им на основе полученных из 
								   приложения сведений, включая покупку игр или замену комплектующих. Со своей стороны, пользователь принимает на себя полную ответственность и обязуется использовать 
								   приложение WillPC в строгом соответствии с действующим законодательством, обязуясь при этом не предпринимать никаких попыток декомпиляции, взлома, нарушения целостности 
								   или дестабилизации работы системы, не внедрять вредоносный код для изменения заложенного поведения программы и не использовать ее механизмы для причинения какого-либо вреда
								   сторонним пользователям, чужим устройствам или конфиденциальным данным. Кроме того, графический интерфейс приложения может содержать различные изображения, скриншоты,
								   зарегистрированные товарные знаки и оригинальные названия игр, которые интегрированы туда исключительно ради визуальной демонстрации возможностей дизайна и обеспечения
								   максимального удобства навигации, при этом все исключительные авторские права на указанные
								   медиаматериалы в полной мере принадлежат их непосредственным и законным правообладателям.
                        " TextWrapping="Wrap" Margin="10,30,0,0" />
                    </ScrollViewer>
                </Border>
                <Button Grid.Row="2" Classes="Agree"
                        Content="Принять"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0"
                        Padding="18,8"
						Foreground="White"
                        Click="AcceptAgreement"/>
                <Button Grid.Row="2"
                        Content="Отказаться" Foreground="White" Classes ="Decline"
                        HorizontalAlignment="Right"
                        Margin="0,16,110,0"
                        Padding="18,8"
                        Click="DeclineAccept"/>
        </Grid>
    
        
        
        
        
        
        
        
        
        
        
        
        
        
        
        
        
        
        
        
</Window>