<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="WillPC.UserAgreementWindow"
        Background="#15212C"
        Width="1024"
        Height="768"
        Foreground="White"
        CanResize="False"
        WindowDecorations="None"
        WindowStartupLocation="CenterScreen"
        Title="WillPC">

    <Window.Styles>
        <Style Selector="Button.Agree">
            <Setter Property="Background" Value="#2F80ED"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18,10"/>
        </Style>

        <Style Selector="Button.Agree:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#4EA2FF"/>
        </Style>

        <Style Selector="Button.Decline">
            <Setter Property="Background" Value="#D83B3B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18,10"/>
        </Style>

        <Style Selector="Button.Decline:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#F05A5A"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto" Margin="28">
        <StackPanel Grid.Row="0" Spacing="6" Margin="0,0,0,18">
            <TextBlock Text="Пользовательское соглашение"
                       FontSize="28"
                       FontWeight="Bold"/>
            <TextBlock Text="Перед запуском WillPC нужно принять условия использования."
                       Foreground="#BFD1E0"
                       FontSize="15"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="#1F2E3D"
                CornerRadius="10"
                BorderBrush="#2D4357"
                BorderThickness="1"
                Padding="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock TextWrapping="Wrap"
                           LineHeight="23"
                           Foreground="#EDF5FC">
                    <Run Text="1. Общие положения"/>
                    <LineBreak/>
                    <Run Text="WillPC помогает получить сведения об играх из Steam и приблизительно оценить, подходит ли конфигурация компьютера под системные требования выбранной игры."/>
                    <LineBreak/>
                    <LineBreak/>
                    <Run Text="2. Данные компьютера"/>
                    <LineBreak/>
                    <Run Text="Приложение может считывать сведения о процессоре, видеокарте, оперативной памяти, свободном месте на диске, версии операционной системы и DirectX. Эти данные используются для оценки совместимости."/>
                    <LineBreak/>
                    <LineBreak/>
                    <Run Text="3. Сторонние сервисы"/>
                    <LineBreak/>
                    <Run Text="Информация об играх загружается через API Steam. Для формирования оценки совместимости может использоваться GigaChat. Ответ ИИ носит справочный характер и не является гарантией запуска игры."/>
                    <LineBreak/>
                    <LineBreak/>
                    <Run Text="4. Ответственность пользователя"/>
                    <LineBreak/>
                    <Run Text="Пользователь самостоятельно принимает решение об установке или покупке игры. WillPC не несет ответственности за изменения системных требований, ошибки сторонних сервисов, сетевые сбои или некорректные данные, полученные из внешних источников."/>
                    <LineBreak/>
                    <LineBreak/>
                    <Run Text="5. Принятие условий"/>
                    <LineBreak/>
                    <Run Text="Нажимая кнопку «Принять», пользователь подтверждает, что ознакомился с соглашением и согласен использовать приложение на указанных условиях. При отказе приложение будет закрыто."/>
                </TextBlock>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0"
                    Spacing="10">
            <Button Classes="Decline"
                    Content="Отказаться"
                    Click="DeclineAccept"/>
            <Button Classes="Agree"
                    Content="Принять"
                    Click="AcceptAgreement"/>
        </StackPanel>
    </Grid>
</Window>
